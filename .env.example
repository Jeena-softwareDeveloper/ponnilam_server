# ──────────────────────────────────────────────
# Server Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Database — PostgreSQL (production / docker-compose)
DATABASE_URL="postgresql://nbfc:nbfc_secret@localhost:5432/nbfc_db?schema=public"

# JSON Web Token secret — use a long random string in production (required)
JWT_SECRET="change_me_to_a_long_random_secret"

# Server port (optional, defaults to 5000)
PORT=5000

# Comma-separated allowed frontend origins for CORS (production)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,https://app.ponnilamfincorp.com,https://ponnilamfinance.com"

# Node environment
NODE_ENV=development
