# =============================================================================
# PONNILAM FIN CORP — Server Environment Variables
# =============================================================================
# LOCAL DEVELOPMENT
#   1. Copy this file to `.env`
#   2. Fill in values (see `.env` in repo for a working dev sample)
#
# PRODUCTION
#   Use `.env.production.example` as a guide
#   Set variables on your VPS / cloud host (PM2, Docker, Railway, etc.)
# =============================================================================

# ── Database (required) ───────────────────────────────────────────────────────
# Dev (SQLite — matches prisma/schema.prisma provider = "sqlite"):
DATABASE_URL="file:./dev.db"

# Prod (PostgreSQL — switch provider in prisma/schema.prisma first):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nbfc_db?schema=public"

# ── Auth (required in production) ─────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS (required in production) ─────────────────────────────────────────────
# Comma-separated frontend URLs allowed to call this API
# Dev:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
# Prod:
# ALLOWED_ORIGINS=https://app.ponnilamfincorp.com
ALLOWED_ORIGINS=

# ── API encryption (required) ─────────────────────────────────────────────────
# 64-character hex — MUST match NEXT_PUBLIC_API_ENCRYPTION_KEY in the UI
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_ENCRYPTION_KEY=

# Set to false only for local debugging without encryption
# API_ENCRYPTION_ENABLED=false

# ── Database seed (dev / first-time setup only) ───────────────────────────────
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PHONE=9000000000
# SEED_ADMIN_EMAIL=admin@ponnilamfincorp.com
# SEED_ADMIN_PASSWORD=           # required when NODE_ENV=production and running db:seed
# SEED_STAFF_PASSWORD=           # required when NODE_ENV=production and running db:seed
