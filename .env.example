# ──────────────────────────────────────────────
# Server Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Database — SQLite (local dev; matches prisma/schema.prisma)
DATABASE_URL="file:./dev.db"
# PostgreSQL (production): switch provider in schema.prisma and use:
# DATABASE_URL="postgresql://nbfc:nbfc_secret@localhost:5432/nbfc_db?schema=public"

# JSON Web Token secret — use a long random string in production (required)
JWT_SECRET="change_me_to_a_long_random_secret"

# Server port (optional, defaults to 5000)
PORT=5000

# Comma-separated allowed frontend origins for CORS (production)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,https://app.ponnilamfincorp.com,https://ponnilamfinance.com"

# Node environment
NODE_ENV=development

# API payload encryption (AES-256-GCM) — must match NEXT_PUBLIC_API_ENCRYPTION_KEY in the UI .env
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_ENCRYPTION_KEY="193978a2fd0d3d11d2016772872420583eb491b746507ee1b15415a156037d69"
# Set to false to disable encryption even when key is present
# API_ENCRYPTION_ENABLED=false
