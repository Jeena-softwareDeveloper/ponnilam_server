generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// Masters
// ==========================================

model State {
  id       String  @id @default(uuid())
  name     String  @unique
  isActive Boolean @default(true)

  districts District[]
  branches  Branch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model District {
  id       String  @id @default(uuid())
  name     String
  isActive Boolean @default(true)

  stateId String
  state   State  @relation(fields: [stateId], references: [id])

  branches Branch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, stateId])
}

model Branch {
  id       String  @id @default(uuid())
  name     String
  code     String  @unique
  location String?
  phone    String?
  isActive Boolean @default(true)

  stateId String?
  state   State?  @relation(fields: [stateId], references: [id])

  districtId String?
  district   District? @relation(fields: [districtId], references: [id])

  areas  Area[]
  staffs Staff[]
  menus  BranchMenu[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Area {
  id       String  @id @default(uuid())
  name     String  @unique
  isActive Boolean @default(true)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  staffs    Staff[]
  centers   Center[]
  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Center {
  id            String  @id @default(uuid())
  name          String  @unique
  code          String? @unique // Optional now, since it wasn't requested, but good to have
  centerTime    String?
  repaymentType String  @default("WEEKLY")
  disbursMode   String  @default("CASH")
  totalMembers  Int     @default(0)
  isActive      Boolean @default(true)

  areaId String
  area   Area   @relation(fields: [areaId], references: [id])

  employeeId String?
  employee   Staff?  @relation(fields: [employeeId], references: [id])

  groups Group[]
  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Group {
  id         String  @id @default(uuid())
  groupCode  String? @unique
  groupName  String
  meetingDay String?
  isActive   Boolean @default(true)

  centerId String
  center   Center @relation(fields: [centerId], references: [id])

  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, groupName])
}

model Role {
  id       String  @id @default(uuid())
  name     String  @unique
  isActive Boolean @default(true)

  staffs Staff[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Menu {
  id       String  @id @default(uuid())
  name     String  @unique // e.g. "Branches", "Staffs"
  path     String? // e.g. "/admin/masters/branches"
  icon     String?
  parentId String?
  parent   Menu?   @relation("MenuToMenu", fields: [parentId], references: [id])
  children Menu[]  @relation("MenuToMenu")

  permissions       StaffMenu[]
  branchPermissions BranchMenu[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  id       String  @id @default(uuid())
  name     String
  username String? @unique
  email    String? @unique
  phone    String  @unique
  password String  @default("password123") // Default for now
  isActive Boolean @default(true)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id])

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  menus       StaffMenu[]
  loans       Loan[] // If a staff is linked to a loan process (optional)
  centers     Center[] // Centers managed by this staff
  customers   Customer[]
  collections Collection[]
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StaffMenu {
  id      String @id @default(uuid())
  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  menuId  String
  menu    Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([staffId, menuId])
}

model BranchMenu {
  id       String @id @default(uuid())
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  menuId   String
  menu     Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([branchId, menuId])
}

model LoanPackage {
  id           String  @id @default(uuid())
  name         String  @unique
  interestRate Float
  durationDays Int
  frequency    String  @default("DAILY") // "DAILY", "WEEKLY", "MONTHLY"
  isActive     Boolean @default(true)

  loans        Loan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Customer Registration
// ==========================================

model Customer {
  id            String    @id @default(uuid())
  customerNo    String    @unique // e.g. CUST0001
  name          String
  dob           DateTime?
  placeOfBirth  String?
  maritalStatus String?
  address       String?
  residenceType String?
  yearsInResidence Int?
  occupation    String?
  phone         String?
  mobile        String?

  // Others Tab
  familyMembers Int       @default(0)
  fatherName    String?
  motherName    String?
  fatherDob     DateTime?
  motherDob     DateTime?

  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id])

  employeeId String?
  employee   Staff?  @relation(fields: [employeeId], references: [id])

  centerId String?
  center   Center? @relation(fields: [centerId], references: [id])

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id])

  coApplicant CustomerCoApplicant?
  kyc         CustomerKyc?
  bank        CustomerBank?
  loans       Loan[]
  customerLedgers CustomerLedger[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerKyc {
  id        String    @id @default(uuid())

  // Primary ID (Proof 1)
  idProof1Type      String?
  idProof1No        String?
  idProof1Name      String?
  idProof1Dob       DateTime?
  idProof1IssueDate DateTime?

  // Secondary ID (Proof 2)
  idProof2Type      String?
  idProof2No        String?
  idProof2Name      String?
  idProof2Dob       DateTime?
  idProof2IssueDate DateTime?

  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerBank {
  id            String  @id @default(uuid())
  accountHolder String?
  accountNumber String?
  ifsc          String?
  bankName      String?
  branchName    String?

  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerCoApplicant {
  id           String    @id @default(uuid())
  name         String?
  dob          DateTime?
  relationship String?
  occupation   String?

  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Transactionals
// ==========================================

model Loan {
  id           String @id @default(uuid())
  loanNumber   String @unique
  amount       Float // Loan Amount
  interestRate Float? // Optional interest rate
  status       String @default("PENDING") // PENDING, APPROVED, DROPPED, ACTIVE, CLOSED
  remarks      String? // Approver remarks

  applicationDate DateTime?
  
  packageId String?
  package   LoanPackage? @relation(fields: [packageId], references: [id])

  // Loan Entry Details
  noOfDues          Int   @default(0)
  perDueAmount      Float @default(0)
  totalDueAmount    Float @default(0)
  deductionAmount   Float @default(0)
  netDisbursement   Float @default(0)
  outstandingAmount Float @default(0) // Live calculated outstanding

  // Income Analysis
  salary      Float @default(0)
  interest    Float @default(0)
  additional  Float @default(0)
  otherIncome Float @default(0)
  totalIncome Float @default(0)

  // Expense Analysis
  food           Float @default(0)
  rent           Float @default(0)
  mobile         Float @default(0)
  education      Float @default(0)
  loanObligation Float @default(0)
  otherExpense   Float @default(0)
  totalExpense   Float @default(0)

  // System Calc
  eligibleEmi Float @default(0)

  // Disbursement
  disbursementDate DateTime?
  firstDueDate     DateTime?

  // Advance Balance Tracker
  advanceBalance Float @default(0)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  schedules   LoanSchedule[]
  collections Collection[]
  guarantors  LoanGuarantor[]
  loanLedgers LoanLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoanSchedule {
  id        String    @id @default(uuid())
  dueDate   DateTime
  emiAmount Float
  status    String    @default("PENDING") // PENDING, PAID
  paidDate  DateTime?

  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Collection {
  id        String   @id @default(uuid())
  trnNumber String   @unique
  trnDate   DateTime
  amount    Float
  remarks   String?

  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id])

  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id])

  schedules       LoanSchedule[] // Which schedules were paid by this collection
  customerLedgers CustomerLedger[]
  loanLedgers     LoanLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Ledgers (Audit Trail)
// ==========================================

model CustomerLedger {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  transactionType String   // "Collection", "Disbursement", "Refund"
  amount          Float
  openingBalance  Float
  closingBalance  Float
  remarks         String?
  
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  
  collectionId    String?
  collection      Collection? @relation(fields: [collectionId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LoanLedger {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  transactionType String   // "EMI Collection", "Penalty", "Disbursement"
  amount          Float
  openingBalance  Float
  closingBalance  Float
  remarks         String?
  
  loanId          String
  loan            Loan     @relation(fields: [loanId], references: [id])
  
  collectionId    String?
  collection      Collection? @relation(fields: [collectionId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// Audit Logs
// ==========================================

model AuditLog {
  id       String  @id @default(uuid())
  action   String // e.g. "CREATE", "UPDATE", "DELETE", "LOGIN"
  entity   String // e.g. "Staff", "Branch", "Loan"
  entityId String? // ID of the affected entity
  details  String? // JSON string or text describing the changes

  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id])

  createdAt DateTime @default(now())
}

model Notification {
  id          String  @id @default(uuid())
  type        String // e.g. "PASSWORD_RESET"
  title       String
  message     String
  isRead      Boolean @default(false)
  referenceId String? // e.g. Staff ID who requested it
  status      String? // e.g. "PENDING", "APPROVED", "REJECTED"

  branchId    String?
  branch      Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoanGuarantor {
  id           String @id @default(uuid())
  name         String
  relationship String
  mobileNo     String

  loanId       String
  loan         Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
