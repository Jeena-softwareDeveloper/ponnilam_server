# =============================================================================
# PRODUCTION — Server (VPS / cloud host)
# =============================================================================
# Set these on your production server. Never commit real secrets to git.
# After setting DATABASE_URL, run: npx prisma db push && npm run db:seed
# =============================================================================

NODE_ENV=production
PORT=5000

# PostgreSQL (switch prisma/schema.prisma provider to "postgresql" first)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/nbfc_db?schema=public

# Strong random secret (required — server refuses to start without this in production)
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Frontend URL(s) that may call this API
ALLOWED_ORIGINS=https://app.ponnilamfincorp.com

# Must match NEXT_PUBLIC_API_ENCRYPTION_KEY in Vercel / UI hosting
API_ENCRYPTION_KEY=REPLACE_WITH_YOUR_64_CHAR_HEX_KEY

# First-time production seed only (then remove or rotate passwords)
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PHONE=9000000000
# SEED_ADMIN_EMAIL=admin@ponnilamfincorp.com
# SEED_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# SEED_STAFF_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
